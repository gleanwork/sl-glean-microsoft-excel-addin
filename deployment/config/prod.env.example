# Copy to prod.env and fill in customer/deployment-specific values.

AWS_PROFILE=default
AWS_REGION=us-east-1
STACK_NAME=glean-in-excel-test
DEPLOYMENT_ID=test

# Test-run target domain.
DOMAIN_NAME=gleaninexcel.gleandemo.com

# CloudFront requires an ACM certificate in us-east-1 for DOMAIN_NAME.
CERTIFICATE_ARN=arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERTIFICATE_ID

# S3 bucket used by aws cloudformation package for Lambda artifacts.
ARTIFACT_BUCKET=glean-in-excel-test-artifacts

# Glean tenant slug, e.g. "acme" for https://acme-be.glean.com.
GLEAN_INSTANCE=your-instance

# Recommended production setting.
OAUTH_CLIENT_TYPE=dcr

# Only used when OAUTH_CLIENT_TYPE=static.
GLEAN_OAUTH_CLIENT_ID=
GLEAN_OAUTH_CLIENT_SECRET=

# Comma-separated Glean user emails that can access admin config routes.
ADMIN_EMAILS=admin@example.com

# Manifest defaults.
ADDIN_ID=42c7fc70-e3ef-42e8-8afd-5a7841ff537d
ADDIN_VERSION=1.0.0.0
